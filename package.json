{
  "name": "parrillero-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "qa:cooking": "tsx scripts/cooking-engine-qa.ts",
    "snapshots:cooking": "tsx scripts/cooking-snapshots.ts",
    "snapshots:cooking:update": "tsx scripts/cooking-snapshots.ts --update",
    "generate:assets": "node scripts/generate-assets.mjs",
    "process:assets": "node scripts/process-assets.mjs",
    "build:asset-map": "node scripts/build-asset-map.mjs",
    "pipeline:assets": "node scripts/pipeline-assets.mjs",
    "process:setup-images": "node scripts/process-setup-images.mjs",
    "generate:setup-images": "node scripts/generate-setup-images.mjs",
    "build:setup-map": "node scripts/build-setup-map.mjs",
    "watch:setup": "chokidar \"assets/raw/setup/*.png\" --command \"npm run process:setup-images\"",
    "pipeline:setup": "npm run pipeline:assets -- setup",
    "pipeline:cuts": "npm run pipeline:assets -- cuts",
    "pipeline:vegetables": "npm run pipeline:assets -- vegetables",
    "pipeline:icons": "npm run pipeline:assets -- icons",
    "pipeline:steps": "npm run pipeline:assets -- steps",
    "pipeline:hero": "npm run pipeline:assets -- hero",
    "qa:responses": "tsx scripts/cooking-response-audit.ts",
    "check:ui": "tsx scripts/print-ui-checklist.ts",
    "check": "npm run lint && npm run build && npm run qa:cooking && npm run check:ui",
    "qa": "npm run qa:cooking && npm run snapshots:cooking && npm run check:ui"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.4",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
